{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "command": ".cursor/hooks/pre-tool-guard.ps1",
        "matcher": "Write|Shell|Task|Delete",
        "timeout": 10
      }
    ],
    "beforeShellExecution": [
      {
        "command": ".cursor/hooks/before-shell-guard.ps1",
        "failClosed": true,
        "timeout": 10
      }
    ],
    "afterFileEdit": [
      {
        "command": ".cursor/hooks/post-edit-verify.ps1",
        "matcher": "Write",
        "timeout": 180
      }
    ],
    "stop": [
      {
        "command": ".cursor/hooks/stop-gate.ps1",
        "loop_limit": 3,
        "timeout": 300
      }
    ],
    "preCompact": [
      {
        "command": ".cursor/hooks/pre-compact-backup.ps1",
        "timeout": 30
      }
    ]
  }
}
