{
  "schemaVersion": 1,
  "events": {
    "harness.eval.completed": {
      "required": [
        "timestamp",
        "caseId",
        "layer",
        "status"
      ],
      "properties": {
        "timestamp": "ISO-8601 UTC",
        "caseId": "eval case id",
        "layer": "harness | graph | agent",
        "status": "passed | failed | skipped",
        "errors": "sanitized error strings"
      },
      "producer": "harness/evals/run.ps1",
      "storage": "harness/evals/results/ (gitignored)"
    },
    "harness.policy.decision": {
      "required": [
        "timestamp",
        "hook",
        "decision",
        "reason"
      ],
      "properties": {
        "timestamp": "ISO-8601 UTC",
        "hook": "pre-tool | pre-shell | post-edit | stop",
        "decision": "allow | deny | gate",
        "reason": "sanitized policy reason"
      },
      "producer": ".codex/hooks/",
      "storage": ".codex/state/ (gitignored) or hook stdout"
    },
    "harness.status.checked": {
      "required": [
        "timestamp",
        "status",
        "lanes"
      ],
      "properties": {
        "timestamp": "ISO-8601 UTC",
        "status": "passed | failed",
        "lanes": "lane validation summaries"
      },
      "producer": "scripts/agent/Get-HarnessStatus.ps1",
      "storage": "command stdout"
    }
  },
  "redaction": {
    "neverRecord": [
      "secrets",
      "tokens",
      ".env contents",
      "raw private tool payloads"
    ]
  }
}
