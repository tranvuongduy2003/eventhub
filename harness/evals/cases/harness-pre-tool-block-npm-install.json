{
  "id": "harness-pre-tool-block-npm-install",
  "layer": "harness",
  "description": "preToolUse denies npm install in web/ (Yarn only)",
  "run": {
    "type": "hook",
    "script": ".codex/hooks/Invoke-PreToolGuard.ps1",
    "stdinFixture": "harness/evals/fixtures/pre-tool-shell-npm.json"
  },
  "assert": {
    "exitCode": 2,
    "json": { "permission": "deny" },
    "stdoutContains": ["Yarn"]
  }
}
