{
  "schemaVersion": 2,
  "type": "object",
  "required": [
    "id",
    "objective",
    "workflow",
    "phase",
    "harnessImpact",
    "memorySyncInventory",
    "doneCriteriaLedger",
    "stopConditions"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^task-[0-9]{14}-[a-z0-9-]+$"
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "workflow": {
      "type": "string",
      "enum": [
        "cook",
        "harness"
      ]
    },
    "phase": {
      "type": "string",
      "enum": [
        "intake",
        "audit",
        "spec",
        "plan",
        "implement",
        "verify",
        "handoff"
      ]
    },
    "artifactMode": {
      "type": "string",
      "enum": [
        "durable",
        "dry-run"
      ],
      "default": "durable"
    },
    "stopAfter": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "spec",
        "plan",
        "implement",
        "verify",
        "done",
        null
      ]
    },
    "relatedSpec": {
      "type": [
        "string",
        "null"
      ]
    },
    "planPath": {
      "type": [
        "string",
        "null"
      ]
    },
    "structuredArtifacts": {
      "type": "object",
      "properties": {
        "specMarkdown": {
          "type": [
            "string",
            "null"
          ]
        },
        "planMarkdown": {
          "type": [
            "string",
            "null"
          ]
        },
        "progressNotes": {
          "type": [
            "string",
            "null"
          ]
        },
        "runtimeStateDirectory": {
          "type": [
            "string",
            "null"
          ]
        },
        "taskSpecSidecar": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "adjacentFeatureBoundary": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "inScope": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "outOfScope": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "neighboringFeatures": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "confidence": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0,
      "maximum": 1
    },
    "harnessImpact": {
      "type": "object",
      "required": [
        "evals",
        "orchestrator",
        "policies",
        "telemetry",
        "tools",
        "workflow"
      ],
      "properties": {
        "evals": {
          "$ref": "#/$defs/impactLane"
        },
        "orchestrator": {
          "$ref": "#/$defs/impactLane"
        },
        "policies": {
          "$ref": "#/$defs/impactLane"
        },
        "telemetry": {
          "$ref": "#/$defs/impactLane"
        },
        "tools": {
          "$ref": "#/$defs/impactLane"
        },
        "workflow": {
          "$ref": "#/$defs/impactLane"
        }
      }
    },
    "memorySyncInventory": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "surface",
          "status"
        ],
        "properties": {
          "surface": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "planned",
              "updated",
              "N/A"
            ]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "doneCriteriaLedger": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "criterion",
          "status"
        ],
        "properties": {
          "criterion": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "passed",
              "failed",
              "N/A"
            ]
          },
          "evidence": {
            "type": "string"
          }
        }
      }
    },
    "stopConditions": {
      "type": "array",
      "items": {
        "type": "string",
          "enum": [
            "checks-passed",
            "memory-synced",
            "done-criteria-ledger-complete",
            "confidence-threshold-met",
            "blocked",
          "user-stop",
          "policy-denied",
          "retry-budget-exhausted"
        ]
      }
    }
  },
  "$defs": {
    "impactLane": {
      "type": "object",
      "required": [
        "status",
        "files",
        "validation"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "none",
            "planned",
            "changed"
          ]
        },
        "files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "validation": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
