{
  "schemaVersion": 2,
  "defaultWorkflow": "cook-unified",
  "canonicalSkill": "cook",
  "memorySyncSkill": "memory-sync",
  "workflows": {
    "cook-unified": {
      "skill": "cook",
      "description": "Single entrypoint for spec, plan, implementation, verification, repair, memory sync, and handoff.",
      "phases": [
        {
          "name": "intake",
          "requiresSourceOfTruth": true
        },
        {
          "name": "spec",
          "stopAfter": "spec",
          "requiresHarnessImpact": true,
          "requiresStructuredArtifact": true,
          "artifact": "docs/_memory/specs/<timestamp>-<slug>.md"
        },
        {
          "name": "plan",
          "stopAfter": "plan",
          "requiresHarnessImpactTable": true,
          "requiresMemorySyncTable": true,
          "requiresStructuredArtifact": true,
          "artifact": ".codex/plans/<same-filename-as-spec>.md"
        },
        {
          "name": "implement",
          "requiresCheckpointLoop": true,
          "requiresHarnessImpactGate": true,
          "requiresMemorySyncGate": true
        },
        {
          "name": "verify",
          "requiresChangedCodeVerification": true,
          "requiresHarnessValidationWhenChanged": true,
          "requiresDocsMemoryValidationWhenChanged": true
        },
        {
          "name": "handoff",
          "requiresMemorySyncComplete": true,
          "requiresSpecImplementedWhenComplete": true
        }
      ]
    },
    "harness-lane-change": {
      "laneSkills": {
        "evals": "harness-evals",
        "orchestrator": "harness-orchestrator",
        "policies": "harness-policies",
        "telemetry": "harness-telemetry",
        "tools": "harness-tools"
      },
      "requiredValidation": [
        "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/agent/Get-HarnessStatus.ps1 -Json",
        "powershell -NoProfile -ExecutionPolicy Bypass -File harness/evals/run.ps1 -Layer harness"
      ]
    }
  },
  "stopConditions": {
    "complete": [
      "acceptance criteria satisfied",
      "changed-code verification passed",
      "harness lane validation passed when a harness lane changed",
      "docs memory validation passed after spec or long-term memory changes",
      "related spec status and all affected memory surfaces synchronized before handoff",
      "confidence threshold met or explicitly waived by user"
    ],
    "blocked": [
      "policy denied required action",
      "required external state unavailable",
      "repeated verifier failure exhausted retry budget",
      "human decision required"
    ]
  }
}
