    "handoff": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/agent/New-PrHandoff.ps1",
    "evalHarness": "powershell -NoProfile -ExecutionPolicy Bypass -File harness/evals/run.ps1 -Layer harness"
  },
  "statusCommand": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/agent/Get-HarnessStatus.ps1 -Json",
  "evalCommand": "powershell -NoProfile -ExecutionPolicy Bypass -File harness/evals/run.ps1 -Layer harness",
  "futureRuntime": {
    "providerContract": "Responses API",
    "orchestration": "Agents SDK",
    "codexExecutor": "Codex CLI via MCP when multi-step coding workflows need external orchestration"
