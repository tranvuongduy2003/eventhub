  "lanes": {
    "evals": {
      "skill": "harness-evals",
      "root": "harness/evals/",
      "artifacts": [
        "harness/evals/run.ps1",
        "harness/evals/cases/",
        "harness/evals/fixtures/"
      ]
    },
    "orchestrator": {
      "skill": "harness-orchestrator",
