{
  "ConnectionStrings": {
    "App": "Host=localhost;Port=5432;Database=app;Username=postgres;Password=postgres",
    "Cache": "localhost:6379"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Session": {
    "CookieName": "Boilerplate.Session",
    "ExpirationHours": 24
  },
  "Concurrency": {
    "MaxRetryAttempts": 3,
    "BaseDelayMilliseconds": 25
  }
}
