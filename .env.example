# Copy to .env for local overrides
ASPNETCORE_ENVIRONMENT=Development
DOTNET_ENVIRONMENT=Development

# PostgreSQL — must match AppHost (src/AppHost/AppHost.cs + Parameters:postgres-password)
# Resource: postgres, database: app, host ports pinned in AppHost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_URI=postgresql://postgres:postgres@localhost:5432/app?sslmode=disable

# Redis — must match AppHost resource "cache", host port 6379
REDIS_HOST=localhost
REDIS_PORT=6379
