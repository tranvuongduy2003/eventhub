{
  "id": "harness-pre-tool-block-npm-install",
  "layer": "harness",
  "description": "preToolUse denies npm install in web/ (Yarn only)",
  "run": {
    "type": "hook",
    "script": ".codex/hooks/pre-tool-guard.ps1",
    "stdinFixture": "evals/fixtures/pre-tool-shell-npm.json"
  },
  "assert": {
    "exitCode": 2,
    "json": { "permission": "deny" },
    "stdoutContains": ["Yarn"]
  }
}
